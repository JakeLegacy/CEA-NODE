<%
var adminLinks = [
  { href: '/admin', label: 'Inicio', active: false },
  { href: '/works/admin', label: 'Obras', active: false },
  { href: '/scores/puntuacion', label: 'Puntuación de Obras', active: false },
  { href: '/admin/panel', label: 'Admin-Panel', active: true }
];
var directions = ['DDAS','DDC','DDD','DDHE','DDS','DGAEI','UPE'];
%>
<%- include('../partials/head', { title: 'Editar Usuario', extraCss: ['general.css'], bodyClass: '' }) %>
<%- include('../partials/navbar', { navHome: '/admin', navTitle: 'Sistema de Gestión de Obras Hídricas – EDITAR USUARIO', navLinks: adminLinks }) %>

<div class="container" style="margin-top:120px; max-width:900px;">
  <%- include('../partials/flash') %>

  <div class="panel panel-primary">
    <div class="panel-heading text-center">
      <h3 class="panel-title">Editar Usuario</h3>
    </div>
    <div class="panel-body">
      <form action="/admin/users/edit/<%= editUser.id_user %>" method="POST">
        <div class="form-group">
          <label>Email:</label>
          <input type="text" class="form-control" name="email" required value="<%= editUser.email %>">
        </div>
        <div class="form-group">
          <label>Contraseña:</label>
          <input type="text" class="form-control" name="password" required value="<%= editUser.password %>">
        </div>
        <div class="form-group">
          <label>Rol:</label>
          <select class="form-control" name="role" required>
            <option value="user" <%= editUser.role === 'user' ? 'selected' : '' %>>Usuario</option>
            <option value="admin" <%= editUser.role === 'admin' ? 'selected' : '' %>>Admin</option>
          </select>
        </div>
        <div class="form-group">
          <label>Dirección:</label>
          <select class="form-control" name="direction" required>
            <% directions.forEach(function(d) { %>
              <option value="<%= d %>" <%= editUser.direction === d ? 'selected' : '' %>><%= d %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-group text-center">
          <button type="submit" class="btn btn-warning btn-lg">Modificar Usuario</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
