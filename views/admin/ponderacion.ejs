<%
var adminLinks = [
  { href: '/admin', label: 'Inicio', active: false },
  { href: '/works/admin', label: 'Obras', active: false },
  { href: '/scores/puntuacion', label: 'Puntuación de Obras', active: true },
  { href: '/admin/panel', label: 'Admin-Panel', active: false }
];
function fmtWeight(val) {
  if (val === null || val === undefined || val === '') return '';
  var s = parseFloat(val).toFixed(4);
  s = s.replace(/0+$/, '').replace(/\.$/, '');
  return s;
}
%>
<%- include('../partials/head', { title: 'Ponderación de Rubros', extraCss: ['obrasadmin.css'], bodyClass: 'obras-admin' }) %>
<%- include('../partials/navbar', { navHome: '/admin', navTitle: 'Sistema de Gestión de Obras Hídricas – Ponderación', navLinks: adminLinks }) %>

<div class="container-narrow">
  <%- include('../partials/flash') %>

  <div class="panel panel-default">
    <div class="panel-heading" style="background-color:#3793ff; color:white;">
      Ponderación de Rubros y Subrubros
    </div>
    <div class="panel-body">
      <p><strong>Modifica los pesos que afectan el cálculo final de cada obra.</strong></p>
      <ul style="font-size:12px;color:#666;">
        <li>Los subrubros dentro de una sección deben sumar <strong>1.00</strong></li>
        <li>Los rubros principales deben tener pesos entre 0 y 1.0</li>
        <li>Usa decimales: 0.17 (no 17%)</li>
      </ul>
    </div>

    <form method="post" action="/scores/ponderacion">
      <% Object.keys(weightsBySection).forEach(function(section) {
        var items = weightsBySection[section];
        var totalSub = 0;
        items.forEach(function(it) { totalSub += parseFloat(it.sub_weight || 0); });
        var isSubValid = Math.abs(totalSub - 1.0) < 0.001;
      %>
      <div style="margin-bottom:30px;border:2px solid #ddd;border-radius:5px;">
        <div style="background-color:#e3f2fd;padding:10px 15px;font-weight:bold;font-size:16px;display:flex;justify-content:space-between;align-items:center;">
          <span><%= section %></span>
          <span style="color:<%= isSubValid ? '#27ae60' : '#e74c3c' %>;font-weight:bold;">
            <%= isSubValid ? '✓' : '✗' %> Suma: <%= totalSub.toFixed(4) %>
          </span>
        </div>
        <div style="padding:15px;">
          <table class="table table-bordered table-striped table-hover" style="margin-bottom:0;">
            <thead style="background:#f5f5f5;">
              <tr>
                <th style="width:30%;">Subrubro</th>
                <th style="width:35%;">Peso del Rubro</th>
                <th style="width:35%;">Peso del Subrubro</th>
              </tr>
            </thead>
            <tbody>
              <% items.forEach(function(w) { %>
              <tr>
                <td><%= w.label || w.code %></td>
                <td>
                  <input type="number" step="0.0001" min="0" max="1" class="form-control"
                    name="weights[<%= w.id_weight %>][rubric]"
                    value="<%= fmtWeight(w.rubric_weight) %>">
                </td>
                <td>
                  <input type="number" step="0.0001" min="0" max="1" class="form-control"
                    name="weights[<%= w.id_weight %>][sub]"
                    value="<%= fmtWeight(w.sub_weight) %>">
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
      <% }); %>

      <div class="text-center" style="padding:20px;">
        <button type="submit" class="btn btn-primary btn-lg">
          <span class="glyphicon glyphicon-floppy-disk"></span> Guardar y Recalcular
        </button>
        <a href="/scores/puntuacion" class="btn btn-default btn-lg">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
