<%
var adminLinks = [
  { href: '/admin', label: 'Inicio', active: false },
  { href: '/works/admin', label: 'Obras', active: true },
  { href: '/scores/puntuacion', label: 'Puntuación de Obras', active: false },
  { href: '/admin/panel', label: 'Admin-Panel', active: false }
];
var municipios = ['Amealco','Arroyo Seco','Cadereyta','Corregidora','El Marqués','Ezequiel Montes','Huimilpan','Jalpan de Serra','Landa de Matamoros','Pedro Escobedo','Peñamiller','Pinal de Amoles','Querétaro','San Joaquín','Tequisquiapan','Tolimán'];
%>
<%- include('../partials/head', { title: 'Editar Obra', extraCss: ['general.css'], bodyClass: '' }) %>
<%- include('../partials/navbar', { navHome: '/admin', navTitle: 'Sistema de Gestión de Obras Hídricas – EDITAR OBRA', navLinks: adminLinks }) %>

<div class="container" style="margin-top:120px; max-width:900px;">
  <%- include('../partials/flash') %>

  <div class="panel panel-primary">
    <div class="panel-heading text-center">
      <h3 class="panel-title">Editar Obra #<%= obra.id_work %></h3>
    </div>
    <div class="panel-body">
      <form action="/works/edit/<%= obra.id_work %>" method="POST">
        <div class="form-group">
          <label>ID de Obra:</label>
          <input type="number" class="form-control" readonly value="<%= obra.id_work %>">
        </div>
        <div class="form-group">
          <label>Programa:</label>
          <input type="text" class="form-control" name="program" value="<%= obra.program %>" required>
        </div>
        <div class="form-group">
          <label>Requiere Usuario:</label>
          <input type="text" class="form-control" name="user_requires" value="<%= obra.user_requires %>" required>
        </div>
        <div class="form-group">
          <label>Referencia de Memo:</label>
          <input type="text" class="form-control" name="memo_reference" value="<%= obra.memo_reference %>" required>
        </div>
        <div class="form-group">
          <label>Cuenta con Proyecto:</label>
          <select class="form-control" name="counts_project" required>
            <option value="si" <%= obra.counts_project === 'si' ? 'selected' : '' %>>Sí</option>
            <option value="no" <%= obra.counts_project === 'no' ? 'selected' : '' %>>No</option>
          </select>
        </div>
        <div class="form-group">
          <label>Número de Expediente:</label>
          <input type="text" class="form-control" name="expedient_no" value="<%= obra.expedient_no %>" required>
        </div>
        <div class="form-group">
          <label>Folio:</label>
          <input type="number" class="form-control" name="folio" value="<%= obra.folio %>" required>
        </div>
        <div class="form-group">
          <label>Nombre del Proyecto:</label>
          <input type="text" class="form-control" name="name_project" value="<%= obra.name_project %>" required>
        </div>
        <div class="form-group">
          <label>Municipio:</label>
          <select class="form-control" name="municipality" required>
            <% municipios.forEach(function(m) { %>
              <option <%= obra.municipality === m ? 'selected' : '' %>><%= m %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-group">
          <label>Habitantes Beneficiados:</label>
          <input type="text" class="form-control" name="benefited_inhabitants" value="<%= obra.benefited_inhabitants %>" required>
        </div>
        <div class="form-group">
          <label>Bloque:</label>
          <input type="text" class="form-control" name="block" value="<%= obra.block %>" required>
        </div>
        <div class="form-group">
          <label>Sub-bloque:</label>
          <input type="text" class="form-control" name="sub_block" value="<%= obra.sub_block %>" required>
        </div>
        <div class="form-group">
          <label>Costo Indice en MDP:</label>
          <input type="number" step="0.01" class="form-control" name="cost_MDP" value="<%= obra.cost_MDP %>" required>
        </div>
        <div class="form-group">
          <label>Presupuesto Base en MDP:</label>
          <input type="number" step="0.01" class="form-control" name="budget_MDP" value="<%= obra.budget_MDP %>" required>
        </div>
        <div class="form-group">
          <label>Impacto:</label>
          <input type="text" class="form-control" name="impact" value="<%= obra.impact %>" required>
        </div>
        <div class="form-group">
          <label>Diámetro de Tubería (Pulgadas):</label>
          <input type="number" step="0.01" class="form-control" name="diameter_tube" value="<%= obra.diameter_tube || '' %>">
        </div>
        <div class="form-group text-center">
          <button type="submit" class="btn btn-warning btn-lg">Modificar Obra</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
