<%
var adminLinks = [
  { href: '/admin', label: 'Inicio', active: false },
  { href: '/works/admin', label: 'Obras', active: false },
  { href: '/scores/puntuacion', label: 'Puntuación de Obras', active: false },
  { href: '/admin/panel', label: 'Admin-Panel', active: true }
];
%>
<%- include('../partials/head', { title: 'Registrar Usuario', extraCss: ['general.css'], bodyClass: '' }) %>
<%- include('../partials/navbar', { navHome: '/admin', navTitle: 'Sistema de Gestión de Obras Hídricas – REGISTRAR USUARIO', navLinks: adminLinks }) %>

<div class="container" style="margin-top:120px; max-width:900px;">
  <%- include('../partials/flash') %>

  <div class="panel panel-primary">
    <div class="panel-heading text-center">
      <h3 class="panel-title">Registrar Nuevo Usuario</h3>
    </div>
    <div class="panel-body">
      <form action="/admin/users/register" method="POST">
        <div class="form-group">
          <label for="id_user">ID de Usuario (Auto-Increment):</label>
          <input type="number" class="form-control" id="id_user" readonly placeholder="ID asignado automáticamente por el sistema">
        </div>
        <div class="form-group">
          <label for="email">Email:</label>
          <input type="text" class="form-control" id="email" name="email" placeholder="No se aceptan nombres, solo emails" required>
        </div>
        <div class="form-group">
          <label for="password">Contraseña:</label>
          <input type="text" class="form-control" id="password" name="password" placeholder="Recomendamos que sea difícil" required>
        </div>
        <div class="form-group">
          <label for="role">Rol en el sistema:</label>
          <select class="form-control" id="role" name="role" required>
            <option value="user">Usuario</option>
            <option value="admin">Admin</option>
          </select>
        </div>
        <div class="form-group">
          <label for="direction">Dirección:</label>
          <select class="form-control" id="direction" name="direction" required>
            <option value="DDAS">DDAS</option>
            <option value="DDC">DDC</option>
            <option value="DDD">DDD</option>
            <option value="DDHE">DDHE</option>
            <option value="DDS">DDS</option>
            <option value="DGAEI">DGAEI</option>
            <option value="UPE">UPE</option>
          </select>
        </div>
        <div class="form-group text-center">
          <button type="submit" class="btn btn-success btn-lg">Registrar Usuario</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
