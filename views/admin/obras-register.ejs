<%
var adminLinks = [
  { href: '/admin', label: 'Inicio', active: false },
  { href: '/works/admin', label: 'Obras', active: true },
  { href: '/scores/puntuacion', label: 'Puntuación de Obras', active: false },
  { href: '/admin/panel', label: 'Admin-Panel', active: false }
];
var municipios = ['Amealco','Arroyo Seco','Cadereyta','Corregidora','El Marqués','Ezequiel Montes','Huimilpan','Jalpan de Serra','Landa de Matamoros','Pedro Escobedo','Peñamiller','Pinal de Amoles','Querétaro','San Joaquín','Tequisquiapan','Tolimán'];
%>
<%- include('../partials/head', { title: 'Registrar Obra', extraCss: ['general.css'], bodyClass: '' }) %>
<%- include('../partials/navbar', { navHome: '/admin', navTitle: 'Sistema de Gestión de Obras Hídricas – REGISTRAR OBRA', navLinks: adminLinks }) %>

<div class="container" style="margin-top:120px; max-width:900px;">
  <%- include('../partials/flash') %>

  <div class="panel panel-primary">
    <div class="panel-heading text-center">
      <h3 class="panel-title">Registrar Nueva Obra</h3>
    </div>
    <div class="panel-body">
      <form action="/works/register" method="POST" enctype="multipart/form-data">
        <div class="form-group">
          <label>ID de Obra (Auto-Increment):</label>
          <input type="number" class="form-control" readonly placeholder="ID asignado automáticamente por el sistema">
        </div>
        <div class="form-group">
          <label for="program">Programa:</label>
          <input type="text" class="form-control" id="program" name="program" placeholder="Ejemplo: Cartera de Obra" required>
        </div>
        <div class="form-group">
          <label for="user_requires">Requiere Usuario:</label>
          <input type="text" class="form-control" id="user_requires" name="user_requires" placeholder="Ejemplo: UPE, DDHE, DDAS, etc." required>
        </div>
        <div class="form-group">
          <label for="memo_reference">Referencia de Memo:</label>
          <input type="text" class="form-control" id="memo_reference" name="memo_reference" placeholder="Si no hay, ingresar 's/n'" required>
        </div>
        <div class="form-group">
          <label for="counts_project">Cuenta con Proyecto:</label>
          <select class="form-control" id="counts_project" name="counts_project" required>
            <option value="si">Sí</option>
            <option value="no">No</option>
          </select>
        </div>
        <div class="form-group">
          <label for="expedient_no">Número de Expediente:</label>
          <input type="text" class="form-control" id="expedient_no" name="expedient_no" placeholder="Si no hay, ingresar 's/n'" required>
        </div>
        <div class="form-group">
          <label for="folio">Folio:</label>
          <input type="number" class="form-control" id="folio" name="folio" placeholder="Ejemplo: 153, 04, INGRESAR SOLO NÚMEROS ENTEROS" required>
        </div>
        <div class="form-group">
          <label for="name_project">Nombre del Proyecto:</label>
          <input type="text" class="form-control" id="name_project" name="name_project" placeholder="Ejemplo: Reposición de pozo Agua Azul, municipio El Marqués." required>
        </div>
        <div class="form-group">
          <label for="municipality">Municipio:</label>
          <select class="form-control" id="municipality" name="municipality" required>
            <% municipios.forEach(function(m) { %>
              <option><%= m %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-group">
          <label for="benefited_inhabitants">Habitantes Beneficiados:</label>
          <input type="text" class="form-control" id="benefited_inhabitants" name="benefited_inhabitants" placeholder="Ejemplo: 2500 (NO PONER COMAS)" required>
        </div>
        <div class="form-group">
          <label for="block">Bloque:</label>
          <input type="text" class="form-control" id="block" name="block" placeholder="Ejemplo: Fuentes de Abastecimiento, Agua Potable, etc." required>
        </div>
        <div class="form-group">
          <label for="sub_block">Sub-bloque:</label>
          <input type="text" class="form-control" id="sub_block" name="sub_block" placeholder="Ejemplo: Fuentes de Abastecimiento, Rehabilitación, etc." required>
        </div>
        <div class="form-group">
          <label for="cost_MDP">Costo Indice en MDP:</label>
          <input type="number" step="0.01" class="form-control" id="cost_MDP" name="cost_MDP" placeholder="Ejemplo: 4.50, 3.25, etc." required>
        </div>
        <div class="form-group">
          <label for="budget_MDP">Presupuesto Base en MDP:</label>
          <input type="number" step="0.01" class="form-control" id="budget_MDP" name="budget_MDP" placeholder="Ejemplo: 0.58, 3.20, etc." required>
        </div>
        <div class="form-group">
          <label for="impact">Impacto:</label>
          <input type="text" class="form-control" id="impact" name="impact" placeholder="Ejemplo: Atender el abatimiento de la fuente actual, etc." required>
        </div>
        <div class="form-group">
          <label for="diameter_tube">Diámetro de Tubería (PDF):</label>
          <input type="file" class="form-control" id="diameter_tube" name="diameter_tube" accept="application/pdf" required>
          <p class="help-block">Solo PDF (máx 10MB).</p>
        </div>
        <div class="form-group text-center">
          <button type="submit" class="btn btn-success btn-lg">Registrar Obra</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
