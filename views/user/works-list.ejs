<%
var userLinks = [
  { href: '/user', label: 'Inicio', active: false },
  { href: '/user/works', label: 'Obras', active: true }
];
var techEnvDirs = ['DDHE','DDD','DGAOT','DDAS'];
%>
<%- include('../partials/head', { title: 'Panel de Obras', extraCss: ['obrasadmin.css'], bodyClass: 'obras-admin' }) %>
<%- include('../partials/navbar', { navHome: '/user', navTitle: 'Sistema de Gestión de Obras Hídricas – PANEL DE OBRAS USER', navLinks: userLinks }) %>

<div class="container" style="margin-top:130px; width:100%">

  <div class="panel panel-primary panel-custom">
    <div class="panel-heading text-center">
      <h3 class="panel-title">Tablero de Obras</h3>
      <small style="color:#fff;">Tu dirección: <strong><%= direction %></strong></small>
    </div>

    <div class="panel-body">
      <%- include('../partials/flash') %>

      <div class="text-center" style="margin-bottom:20px;">
        <a href="/user/works" class="btn btn-default">Limpiar</a>
        <a href="/user/works/register" class="btn btn-success">Registrar Obra</a>
      </div>

      <form method="get" class="input-group input-group-lg" style="margin-bottom:20px;">
        <input type="text" name="q" class="form-control" placeholder="Buscar obra por nombre, municipio o programa" value="<%= search %>">
        <span class="input-group-btn">
          <button class="btn btn-primary" type="submit">
            <span class="glyphicon glyphicon-search"></span> Buscar
          </button>
        </span>
      </form>

      <div class="table-scroll">
        <table class="table table-bordered table-striped table-hover">
          <thead>
            <tr>
              <th>ID</th>
              <th>Proyecto</th>
              <th>Municipio</th>
              <th>Programa</th>
              <th>Usuario que Requiere</th>
              <th>Memo Referencia</th>
              <th>¿Cuenta con Proyecto?</th>
              <th>Número de Expediente</th>
              <th>Folio</th>
              <th>Habitantes Beneficiados</th>
              <th>Bloque</th>
              <th>Subbloque</th>
              <th>Costo (MDP)</th>
              <th>Esquema Hidraulico</th>
              <th style="width:190px;text-align:center;">Acción</th>
            </tr>
          </thead>
          <tbody>
            <% works.forEach(function(obra) {
              var idw = obra.id_work;
              var done = completedWorks[idw] || false;
              var requestedDir = (obra.user_requires || '').toUpperCase().trim();
              var canByRequester = true;
              if (techEnvDirs.indexOf(requestedDir) !== -1) {
                canByRequester = (direction.toUpperCase() === requestedDir);
              }
            %>
            <tr>
              <td><%= idw %></td>
              <td><%= obra.name_project %></td>
              <td><%= obra.municipality %></td>
              <td><%= obra.program %></td>
              <td><%= obra.user_requires %></td>
              <td><%= obra.memo_reference %></td>
              <td><%= obra.counts_project %></td>
              <td><%= obra.expedient_no %></td>
              <td><%= obra.folio %></td>
              <td><%= obra.benefited_inhabitants %></td>
              <td><%= obra.block %></td>
              <td><%= obra.sub_block %></td>
              <td><%= obra.cost_MDP %></td>
              <td class="text-center">
                <% if (obra.diameter_tube) { %>
                  <a href="/pdf/view/<%= idw %>" class="btn btn-info btn-sm" target="_blank">
                    <span class="glyphicon glyphicon-file"></span> Ver PDF
                  </a>
                <% } else { %>
                  <span class="text-muted">Sin PDF</span>
                <% } %>
              </td>
              <td class="text-center">
                <% if (!canByRequester) { %>
                  <button class="btn btn-default btn-sm" disabled title="Esta obra la debe calificar la dirección que la solicitó (<%= requestedDir %>).">
                    <span class="glyphicon glyphicon-ban-circle"></span> No te corresponde
                  </button>
                <% } else if (done) { %>
                  <button class="btn btn-success btn-sm" disabled>
                    <span class="glyphicon glyphicon-ok"></span> Completado
                  </button>
                <% } else { %>
                  <a href="/user/works/mark/<%= idw %>" class="btn btn-warning btn-sm">
                    <span class="glyphicon glyphicon-stats"></span> Calificar
                  </a>
                <% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <div class="text-center">
        <ul class="pagination">
          <li class="<%= page <= 1 ? 'disabled' : '' %>">
            <a href="?page=<%= Math.max(1, page - 1) %>&q=<%= encodeURIComponent(search) %>">«</a>
          </li>
          <% for (var i = 1; i <= totalPages; i++) { %>
            <li class="<%= page === i ? 'active' : '' %>">
              <a href="?page=<%= i %>&q=<%= encodeURIComponent(search) %>"><%= i %></a>
            </li>
          <% } %>
          <li class="<%= page >= totalPages ? 'disabled' : '' %>">
            <a href="?page=<%= Math.min(totalPages, page + 1) %>&q=<%= encodeURIComponent(search) %>">»</a>
          </li>
        </ul>
      </div>

    </div>
  </div>
</div>

<%- include('../partials/footer') %>
