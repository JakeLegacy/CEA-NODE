<%
var userLinks = [
  { href: '/user', label: 'Inicio', active: false },
  { href: '/user/works', label: 'Obras', active: false }
];
var puedeCalificar = allowedSections.length > 0;
function selectOptions(name, label) {
  var html = '<div class="form-group"><label>' + label + '</label>';
  html += '<select name="' + name + '" class="form-control" required>';
  html += '<option value="">Selecciona...</option>';
  for (var i = 1; i <= 5; i++) html += '<option value="' + i + '">' + i + '</option>';
  html += '</select></div>';
  return html;
}
%>
<%- include('../partials/head', { title: 'Calificar Obra', extraCss: ['general.css', 'navbar.css'], bodyClass: '' }) %>
<%- include('../partials/navbar', { navHome: '/user', navTitle: 'Sistema de Gestión de Obras Hídricas – CALIFICAR OBRA', navLinks: userLinks }) %>

<div class="container" style="margin-top:130px; max-width:900px;">
  <%- include('../partials/flash') %>

  <div class="panel panel-info">
    <div class="panel-heading">
      <h3 class="panel-title">Obra #<%= obra.id_work %> – <%= obra.name_project %></h3>
    </div>
    <div class="panel-body">
      <p><strong>Municipio:</strong> <%= obra.municipality %></p>
      <p><strong>Programa:</strong> <%= obra.program %></p>
      <p><strong>Usuario que Requiere:</strong> <%= obra.user_requires %></p>
      <p><strong>Memo Referencia:</strong> <%= obra.memo_reference %></p>
      <p><strong>¿Cuenta con proyecto?:</strong> <%= obra.counts_project %></p>
      <p><strong>Número de expediente:</strong> <%= obra.expedient_no %></p>
      <p><strong>Folio:</strong> <%= obra.folio %></p>
      <p><strong>Habitantes Beneficiados:</strong> <%= obra.benefited_inhabitants %></p>
      <p><strong>Bloque:</strong> <%= obra.block %></p>
      <p><strong>Sub-Bloque:</strong> <%= obra.sub_block %></p>
      <p><strong>Costo (en MDP):</strong> <%= obra.cost_MDP %></p>
      <p><strong>Tu dirección:</strong> <%= direction %></p>
    </div>
  </div>

  <% if (!puedeCalificar) { %>
    <div class="alert alert-warning text-center">
      Esta obra ya fue calificada en tu(s) rubro(s) por otra cuenta de tu misma área.
    </div>
  <% } else { %>

    <form method="post" action="/user/works/mark" class="panel panel-primary">
      <div class="panel-heading">
        <h3 class="panel-title">Calificación de la obra</h3>
      </div>
      <div class="panel-body">
        <input type="hidden" name="id_work" value="<%= obra.id_work %>">
        <input type="hidden" name="direction" value="<%= direction %>">

        <% if (allowedSections.indexOf('socioeconomic') !== -1) { %>
          <h4>Socioeconómico (UPE)</h4>
          <div class="form-group">
            <label>Población (Habitantes) (Número entero)</label>
            <input type="text" name="poblacionhab" class="form-control" required>
          </div>
          <%- selectOptions('poblacion', 'Población (1–5)') %>
          <%- selectOptions('valor', 'Valor (1–5)') %>
          <div class="form-group">
            <label>Inversión per Cápita ($/hab)</label>
            <input type="text" name="inversion" class="form-control" required>
          </div>
          <%- selectOptions('categoria', 'Categoría (1–5)') %>
          <%- selectOptions('generacion', 'Generación de ingresos o ahorros (1–5)') %>
          <%- selectOptions('crecimiento', 'Crecimiento poblacional (1–5)') %>
          <hr>
        <% } %>

        <% if (allowedSections.indexOf('tecnic') !== -1) { %>
          <h4>Técnico</h4>
          <%- selectOptions('importancia', 'Importancia de la obra (1–5)') %>
          <%- selectOptions('caudal', 'Caudal recuperado (1–5)') %>
          <%- selectOptions('problematica', 'Problemática actual (1–5)') %>
          <hr>
        <% } %>

        <% if (allowedSections.indexOf('environment') !== -1) { %>
          <h4>Ambiental</h4>
          <%- selectOptions('impactoambiental', 'Impacto ambiental (1–5)') %>
          <%- selectOptions('compromisoambiental', 'Compromiso (1–5)') %>
          <hr>
        <% } %>

        <% if (allowedSections.indexOf('social') !== -1) { %>
          <h4>Social</h4>
          <%- selectOptions('necesidad', 'Necesidad del servicio (1–5)') %>
          <%- selectOptions('riesgo', 'Riesgo social (1–5)') %>
          <%- selectOptions('apoyo', 'Apoyo a la marginación (1–5)') %>
          <hr>
        <% } %>

        <% if (allowedSections.indexOf('politic') !== -1) { %>
          <h4>Político</h4>
          <%- selectOptions('impactopolitico', 'Impacto político (1–5)') %>
          <%- selectOptions('compromiso', 'Compromiso (1–5)') %>
          <hr>
        <% } %>

        <% if (allowedSections.indexOf('legal') !== -1) { %>
          <h4>Jurídico</h4>
          <%- selectOptions('permisos', 'Permisos (1–5)') %>
          <%- selectOptions('leg_riesgo', 'Derechos de paso (1–5)') %>
          <hr>
        <% } %>

        <div class="text-center">
          <button type="submit" class="btn btn-primary btn-lg">Guardar calificación</button>
          <a href="/user/works" class="btn btn-default btn-lg">Cancelar</a>
        </div>

      </div>
    </form>

  <% } %>
</div>

<%- include('../partials/footer') %>
