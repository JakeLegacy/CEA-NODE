<script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
<script>
(function(){
  var activated = false;
  window.addEventListener('scroll', function(){
    if (window.pageYOffset > 40) {
      if (!activated){ document.body.classList.add('overlap'); activated = true; }
    } else {
      if (activated){ document.body.classList.remove('overlap'); activated = false; }
    }
  });
})();
</script>
</body>
